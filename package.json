{
  "name": "woodlands-family-practice",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "browserslist": [
    "Chrome >= 120",
    "Firefox >= 121",
    "Safari >= 17",
    "Edge >= 120"
  ],
  "scripts": {
    "dev": "next dev -p ${PORT:-3000}",
    "dev:poll": "WATCHPACK_POLLING=true next dev -p ${PORT:-3000}",
    "build": "STATIC_EXPORT=true next build",
    "start": "serve out -l ${PORT:-3000}",
    "lint": "next lint"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
